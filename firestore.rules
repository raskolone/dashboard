rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Master catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidTask(data, userId) {
      return data.keys().hasAll(['userId', 'title', 'status', 'priority', 'category', 'due_date', 'createdAt', 'updatedAt'])
        && data.userId == userId
        && data.title is string && data.title.size() <= 200
        && (data.description == null || (data.description is string && data.description.size() <= 2000))
        && data.status in ['todo', 'in_progress', 'done']
        && data.priority in ['low', 'medium', 'high', 'urgent']
        && data.category in ['work', 'personal', 'learning', 'health', 'project']
        && data.due_date is string && data.due_date.size() <= 20
        && (data.color == null || (data.color is string && data.color.size() <= 20))
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidHabit(data, userId) {
      return data.keys().hasAll(['userId', 'name', 'icon', 'frequency', 'target_count', 'color', 'completedDates', 'createdAt', 'updatedAt', 'tags'])
        && data.userId == userId
        && data.name is string && data.name.size() <= 100
        && data.icon is string && data.icon.size() <= 100
        && data.frequency in ['daily', 'weekly']
        && data.target_count is number && data.target_count >= 1 && data.target_count <= 100
        && data.color is string && data.color.size() <= 20
        && data.completedDates is list && data.completedDates.size() <= 2000 // bounded size
        && data.tags is list && data.tags.size() <= 20
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidEvent(data, userId) {
      return data.keys().hasAll(['userId', 'title', 'date', 'start_time', 'end_time', 'type', 'createdAt', 'updatedAt'])
        && data.userId == userId
        && data.title is string && data.title.size() <= 200
        && data.date is string && data.date.size() <= 20
        && data.start_time is string && data.start_time.size() <= 20
        && data.end_time is string && data.end_time.size() <= 20
        && data.type in ['meeting', 'lesson', 'personal', 'deadline', 'reminder']
        && (data.description == null || (data.description is string && data.description.size() <= 2000))
        && (data.location == null || (data.location is string && data.location.size() <= 500))
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidKnowledge(data, userId) {
      return data.keys().hasAll(['userId', 'title', 'content', 'category', 'tags', 'is_pinned', 'createdAt', 'updatedAt'])
        && data.userId == userId
        && data.title is string && data.title.size() <= 200
        && data.content is string && data.content.size() <= 100000
        && data.category in ['Notes', 'Ideas', 'Bookmarks', 'Resources', 'Snippets']
        && data.tags is list && data.tags.size() <= 20
        && data.is_pinned is bool
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    match /users/{userId} {
      match /tasks/{taskId} {
        allow read: if isOwner(userId) && isValidId(taskId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(taskId)
          && isValidTask(incoming(), userId)
          && incoming().createdAt == request.time
          && incoming().updatedAt == request.time;
        allow update: if isOwner(userId) && isValidId(taskId)
          && isValidTask(incoming(), userId)
          && incoming().createdAt == existing().createdAt
          && incoming().updatedAt == request.time;
        allow delete: if isOwner(userId) && isValidId(taskId);
      }

      match /habits/{habitId} {
        allow read: if isOwner(userId) && isValidId(habitId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(habitId)
          && isValidHabit(incoming(), userId)
          && incoming().createdAt == request.time
          && incoming().updatedAt == request.time;
        allow update: if isOwner(userId) && isValidId(habitId)
          && isValidHabit(incoming(), userId)
          && incoming().createdAt == existing().createdAt
          && incoming().updatedAt == request.time;
        allow delete: if isOwner(userId) && isValidId(habitId);
      }

      match /events/{eventId} {
        allow read: if isOwner(userId) && isValidId(eventId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(eventId)
          && isValidEvent(incoming(), userId)
          && incoming().createdAt == request.time
          && incoming().updatedAt == request.time;
        allow update: if isOwner(userId) && isValidId(eventId)
          && isValidEvent(incoming(), userId)
          && incoming().createdAt == existing().createdAt
          && incoming().updatedAt == request.time;
        allow delete: if isOwner(userId) && isValidId(eventId);
      }

      match /knowledge/{knowledgeId} {
        allow read: if isOwner(userId) && isValidId(knowledgeId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(knowledgeId)
          && isValidKnowledge(incoming(), userId)
          && incoming().createdAt == request.time
          && incoming().updatedAt == request.time;
        allow update: if isOwner(userId) && isValidId(knowledgeId)
          && isValidKnowledge(incoming(), userId)
          && incoming().createdAt == existing().createdAt
          && incoming().updatedAt == request.time;
        allow delete: if isOwner(userId) && isValidId(knowledgeId);
      }
    }
  }
}
